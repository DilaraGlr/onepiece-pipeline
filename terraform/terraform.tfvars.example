# ============================================================
# TERRAFORM VARIABLES - EXEMPLE
# ============================================================
# Ce fichier montre le format attendu pour terraform.tfvars
#
# INSTRUCTIONS :
# 1. Copiez ce fichier : cp terraform.tfvars.example terraform.tfvars
# 2. Remplacez les valeurs d'exemple par vos vraies valeurs
# 3. NE COMMITEZ JAMAIS terraform.tfvars dans Git (déjà dans .gitignore)
# ============================================================

# ID du compte de facturation Google Cloud
# Format: XXXXXX-XXXXXX-XXXXXX
# Trouvez-le via : gcloud billing accounts list
# Ou dans la console : https://console.cloud.google.com/billing
billing_account_id = "XXXXXX-XXXXXX-XXXXXX"

# Montant du budget mensuel en EUR (ajustez selon vos besoins)
# monthly_budget_amount = "50"

# Tag Docker des images (optionnel, défaut: "latest")
# image_tag = "latest"

# Nombre de chapitres à scraper (optionnel, défaut: "3")
# chapter_limit = "3"
